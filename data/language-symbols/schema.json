{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reetpetite.github.io/MonkeyOffice-SDK/data/language-symbols/schema.json",
  "title": "MonKey Office language symbol registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "symbols"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "symbols": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/symbol"
      }
    }
  },
  "$defs": {
    "symbol": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "spelling",
        "canonicalSpelling",
        "caseInsensitive",
        "status",
        "evidence",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(kw|op)-[a-z][a-z0-9-]*$"
        },
        "kind": {
          "enum": [
            "keyword",
            "operator"
          ]
        },
        "spelling": {
          "type": "string",
          "minLength": 1
        },
        "canonicalSpelling": {
          "type": "string",
          "minLength": 1
        },
        "caseInsensitive": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "documented",
            "verified",
            "inferred",
            "hypothesis"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "arity": {
          "enum": [
            "unary",
            "binary"
          ]
        },
        "precedenceGroup": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "associativity": {
          "enum": [
            "left",
            "right",
            "none"
          ]
        },
        "evaluation": {
          "enum": [
            "eager",
            "short-circuit",
            "not-applicable"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reetpetite.github.io/MonkeyOffice-SDK/data/statements/schema.json",
  "title": "MonKey Office statement registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "statements"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "statements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/statement"
      }
    }
  },
  "$defs": {
    "statement": {
      "type": "object",
      "required": [
        "id",
        "symbolId",
        "astKind",
        "form",
        "status",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^statement-[a-z][a-z0-9-]*$"
        },
        "symbolId": {
          "type": "string",
          "pattern": "^kw-[a-z][a-z0-9-]*$"
        },
        "astKind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "form": {
          "enum": [
            "keyword-identifier"
          ]
        },
        "status": {
          "enum": [
            "documented",
            "verified",
            "inferred",
            "hypothesis"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

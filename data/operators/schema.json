{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reetpetite.github.io/MonkeyOffice-SDK/data/operators/schema.json",
  "title": "MonKey Office operator registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "operators"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operator"
      }
    }
  },
  "$defs": {
    "operator": {
      "type": "object",
      "required": [
        "id",
        "symbolId",
        "fixity",
        "precedence",
        "associativity",
        "evaluation",
        "status",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^operator-[a-z][a-z0-9-]*$"
        },
        "symbolId": {
          "type": "string",
          "pattern": "^op-[a-z][a-z0-9-]*$"
        },
        "fixity": {
          "enum": [
            "prefix",
            "infix"
          ]
        },
        "precedence": {
          "type": "integer",
          "minimum": 0
        },
        "associativity": {
          "enum": [
            "left",
            "right",
            "none"
          ]
        },
        "evaluation": {
          "enum": [
            "eager",
            "short-circuit"
          ]
        },
        "status": {
          "enum": [
            "documented",
            "verified",
            "inferred",
            "hypothesis"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
